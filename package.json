{
  "name": "pixel-scaler",
  "private": true,
  "version": "1.1.3",
  "type": "module",
  "homepage": "https://irokaru.github.io/pixel-scaler",
  "repository": "https://github.com/irokaru/pixel-scaler",
  "author": {
    "name": "irokaru",
    "email": "karuta@nononotyaya.net",
    "url": "https://nononotyaya.net/"
  },
  "scripts": {
    "dev": "vite",
    "dev:tauri": "tauri dev",
    "build": "vue-tsc -b tsconfig.app.json tsconfig.node.json && vite build",
    "build:standalone": "vue-tsc -b tsconfig.app.json tsconfig.node.json && vite build --mode standalone",
    "build:tauri": "tauri build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:browser": "bun run test -- --project browser",
    "test:browser:watch": "bun run test:watch -- --project browser",
    "test:e2e": "playwright test",
    "lint-staged": "lint-staged",
    "tauri": "tauri",
    "prepare": "test -d .husky && husky || echo 'Skipping husky'; playwright install || echo 'Skipping playwright'"
  },
  "engines": {
    "bun": "1.3.10"
  },
  "packageManager": "bun@1.3.11",
  "dependencies": {
    "@fortawesome/fontawesome-svg-core": "^7.2.0",
    "@fortawesome/free-brands-svg-icons": "^7.2.0",
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@fortawesome/vue-fontawesome": "^3.1.3",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "fflate": "^0.8.2",
    "gifenc": "mattdesl/gifenc#27db5b982dba701ca440b55ea36fad3999040973",
    "gifuct-js": "^2.1.2",
    "pinia": "^3.0.4",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-gtag": "^3.7.0",
    "vue-i18n": "^11.3.0",
    "xbr-js": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@pinia/testing": "^1.0.3",
    "@playwright/test": "^1.58.2",
    "@tauri-apps/cli": "^2.10.1",
    "@types/license-checker": "^25.0.6",
    "@types/wicg-file-system-access": "^2023.10.7",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "@vitest/eslint-plugin": "^1.6.12",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "bun-types": "1.3.11",
    "eslint": "^10.1.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-unicorn": "^63.0.0",
    "eslint-plugin-unused-imports": "^4.4.1",
    "globals": "^17.4.0",
    "happy-dom": "^20.8.4",
    "husky": "^9.1.7",
    "jiti": "^2.6.1",
    "license-checker": "^25.0.1",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1",
    "unplugin-fonts": "^1.4.0",
    "vite": "^8.0.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.1.0",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.6"
  },
  "lint-staged": {
    "*.{js,ts,vue}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,scss}": [
      "prettier --write"
    ]
  }
}
