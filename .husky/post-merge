CHANGED_FILES=$(git diff-tree -r --name-only --no-commit-id ORIG_HEAD HEAD)

# TODO: confirm the operation
if echo "$CHANGED_FILES" | grep -qE 'package\.json|bun\.lock(b)?'; then
  echo "Run \"bun install --frozen-lockfile\" because package.json or bun.lock changed"
  bun install --frozen-lockfile
fi
